# =============================================================================
#  ENVIRONMENT VARIABLES — copy this file to `.env` and fill in real values.
#  NEVER commit `.env`. Vite only exposes vars prefixed with VITE_ to the client.
#  Secret keys (OpenAI, ElevenLabs) must live SERVER-SIDE only — see docs/ARCHITECTURE.md.
# =============================================================================

# --- Client-safe (VITE_) ----------------------------------------------------
# Base URL of your serverless API / backend that proxies AI calls.
VITE_API_BASE_URL="http://localhost:3000/api"

# Feature flags (true/false) to toggle heavy features during development.
VITE_ENABLE_AI_GUIDE="false"
VITE_ENABLE_AUDIO="true"
VITE_FORCE_TIER=""           # "" | "high" | "standard" | "basic"  (override fidelity tier for testing)

# --- Server-only secrets (DO NOT prefix with VITE_) -------------------------
# These are read by api/chat.ts (and future functions), never shipped to browser.
# The proxy prefers Anthropic if present, else OpenAI. Set ONE of them.
ANTHROPIC_API_KEY=""         # Recommended — Claude (most capable) for AI guide / GenUI
ANTHROPIC_MODEL="claude-opus-4-8"
OPENAI_API_KEY=""            # Alternative — GPT-4 family
OPENAI_MODEL="gpt-4o"
ELEVENLABS_API_KEY=""        # Human-like narration (QR Code Talk)
ELEVENLABS_VOICE_ID=""
REPLICATE_API_TOKEN=""       # AI image remix (optional)
BOTNOI_TOKEN=""              # Thai voice narration (optional)

# --- Deployment (optional) --------------------------------------------------
VITE_SITE_URL="https://your-portfolio.example.com"
